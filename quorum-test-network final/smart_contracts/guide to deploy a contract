## 3. How the deployment / interaction script works (`add_tx.js`)

The script `smart_contracts/scripts/public/add_tx.js`:

1. Connects to the Quorum‑test‑network RPC,  
2. Reads `AddTwoValues.json`,  
3. Deploys `AddTwoValues` using `ethers.ContractFactory`,  
4. Calls `add(a, b)` and `getResult()`.

### 3.1 Script overview

```js
const path = require('path');
const fs = require('fs-extra');
const ethers = require('ethers');

// 1. RPC node and account
const { tessera, besu } = require("../keys.js");
const host = besu.rpcnode.url;                      // e.g., http://localhost:21001
const accountPrivateKey = besu.rpcnode.accountPrivateKey;

// 2. Load AddTwoValues ABI + bytecode
const contractJsonPath = path.resolve(__dirname, '../../', 'contracts', 'AddTwoValues.json');
const contractJson = JSON.parse(fs.readFileSync(contractJsonPath));
const contractAbi = contractJson.abi;
const contractBytecode = contractJson.evm.bytecode.object;

// 3. Read the stored result
async function getResultAtAddress(provider, deployedContractAbi, deployedContractAddress) {
  const contract = new ethers.Contract(deployedContractAddress, deployedContractAbi, provider);
  const res = await contract.getResult();
  console.log("On-chain result:", res.toString());
  return res;
}

// 4. Call add(a, b)
async function addTwoValuesAtAddress(provider, wallet, deployedContractAbi, deployedContractAddress, a, b) {
  const contract = new ethers.Contract(deployedContractAddress, deployedContractAbi, provider);
  const contractWithSigner = contract.connect(wallet);
  const tx = await contractWithSigner.add(a, b);
  await tx.wait();
  console.log("add(%d, %d) confirmed.", a, b);
  return tx;
}

// 5. Deploy function
async function createContract(provider, wallet, contractAbi, contractBytecode) {
  const factory = new ethers.ContractFactory(contractAbi, contractBytecode, wallet);
  const contract = await factory.deploy();
  const deployed = await contract.waitForDeployment();
  return contract;
}

// 6. Main flow
async function main() {
  const provider = new ethers.JsonRpcProvider(host);
  const wallet = new ethers.Wallet(accountPrivateKey, provider);

  console.log("Deploying AddTwoValues...");
  createContract(provider, wallet, contractAbi, contractBytecode)
    .then(async (contract) => {
      const contractAddress = await contract.getAddress();
      console.log("AddTwoValues deployed at address:", contractAddress);

      await addTwoValuesAtAddress(provider, wallet, contractAbi, contractAddress, 10, 20);
      await getResultAtAddress(provider, contractAbi, contractAddress);

      await addTwoValuesAtAddress(provider, wallet, contractAbi, contractAddress, 5, 7);
      await getResultAtAddress(provider, contractAbi, contractAddress);
    })
    .catch((err) => {
      console.error("Deployment or interaction failed:", err);
      console.error("Stack trace:", err.stack);
    });
}

if (require.main === module) {
  main();
}

module.exports = main;
```

### 3.2 Key components explained

- `path` + `fs-extra`:
  - Used to locate and read `AddTwoValues.json` correctly, regardless of where you run the script from.  

- `ethers.JsonRpcProvider(host)`:
  - Connects to your Quorum validator RPC (`http://localhost:21001` by default) and speaks Ethereum JSON‑RPC.

- `ethers.Wallet(accountPrivateKey, provider)`:
  - Constructs an Ethereum account from your private key and binds it to the provider.  
  - This wallet is used to sign deployment and `add()` transactions.

- `ethers.ContractFactory`:
  - Takes `contractAbi` (interface) and `contractBytecode` (logic) and knows how to:
    - Encode the constructor call (`factory.deploy()`),  
    - Send a `contract‑creation` transaction to the node.

- `factory.deploy()`:
  - Sends a **contract‑creation transaction** to the Quorum node.  
  - `waitForDeployment()` waits until the transaction is included in a block and the contract is live.

- `new ethers.Contract(address, abi, provider)`:
  - Binds JavaScript to the on‑chain contract at `address` using the `abi`.  
  - Provides typed methods like `add(a, b)` and `getResult()`.

- `add(a, b)`:
  - Sends a **state‑mutating transaction** (`eth_sendSignedTransaction`) to the node.  
  - Must be signed by the wallet and pays gas (though Quorum often uses `gasPrice: 0`).

- `getResult()`:
  - Issues a `eth_call` (read‑only, no gas‑paid write).  
  - Returns the current value of `result`.

